*MAT_HOT_FORMING
"Optional title"
mid,  ρ,  E,  ν,  did,  thpid
c_01,  c_02,  c_s1,  c_s2,  B,  Q,  ̇ε_off
d_1,  d_2,  d_3,  d_4,  d_5,  Q_rex
M,  α,  U_0,  V_0,  v_D,
e_1,  e_2,  l_ref,  l_0,  l_cap,  l_ini
